{
  "name": "gravity-components",
  "version": "0.1.0",
  "description": "A drop-in, fully themed admin UI kit built on Ant Design v6",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/theme.d.ts",
        "default": "./dist/theme.js"
      },
      "require": {
        "types": "./dist/theme.d.cts",
        "default": "./dist/theme.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build",
    "size": "size-limit",
    "check-size": "size-limit --why"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "25 kB"
    },
    {
      "path": "dist/theme.js",
      "limit": "5 kB"
    }
  ],
  "peerDependencies": {
    "antd": ">=6.0.0 <7.0.0",
    "dayjs": ">=1.11.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "sonner": ">=2.0.0 <3.0.0",
    "styled-components": ">=6.0.0"
  },
  "keywords": [
    "react",
    "antd",
    "ant-design",
    "admin",
    "component-library",
    "design-system",
    "ui-kit",
    "typescript",
    "sonner",
    "toast",
    "notifications"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gravity-components/gravity-components.git"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.1",
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "antd": "^6.3.5",
    "dayjs": "^1.11.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "lucide-react": "^1.7.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "size-limit": "^12.0.1",
    "sonner": "^2.0.7",
    "storybook": "^10.3.3",
    "styled-components": "^6.3.12",
    "tsup": "^8.5.1",
    "typescript": "~5.8",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
